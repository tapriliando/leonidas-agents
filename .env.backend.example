# Copy to .env.backend and fill values.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o-mini
MCP_SERVER_URL=http://localhost:8001
REDIS_URL=
# Optional MCP tool secrets: copy .env.mcp.example -> .env.mcp (loaded by mcp_server when present).
# Optional: Postgres checkpointer for LangGraph
# DATABASE_URL=postgresql://...
# USE_MEMORY_CHECKPOINTER=1
# Gateway / evaluation
# HEARTBEAT_AGENT_INTERVAL_SEC=600
# EVAL_METRICS_DISABLED=0
