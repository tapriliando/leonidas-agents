# Optional MCP secrets (copy to `.env.mcp` — loaded automatically when present).
# Basic runs work without this file (e.g. web_search may use DuckDuckGo fallback).

# Optional — better web search quality
# TAVILY_API_KEY=

# Optional — Supabase-backed tools
# SUPABASE_URL=
# SUPABASE_KEY=

# Optional — Redis-backed cache tools (match Redis URL if used)
# REDIS_URL=

# Optional — Google Places / HeyGen (only if you enable those tools)
# GOOGLE_MAPS_API_KEY=
# HEYGEN_API_KEY=
